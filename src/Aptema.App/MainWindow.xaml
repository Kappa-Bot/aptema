<Window x:Class="Aptema.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:presentation="clr-namespace:Aptema.App.Presentation"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        mc:Ignorable="d"
        Title="Aptema"
        Icon="Assets/Aptema.ico"
        Width="1080"
        Height="720"
        MinWidth="900"
        MinHeight="640"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="226" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushMuted}" BorderThickness="0,0,1,0">
            <Grid Margin="20,24,16,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Button Grid.Row="0" Command="{Binding ShowHomeCommand}" Style="{StaticResource NavigationButton}"
                        Padding="0" AutomationProperties.Name="Open Aptema home">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="Assets/Aptema-48.png" Width="42" Height="42" />
                        <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Aptema" FontSize="22" FontWeight="SemiBold" />
                            <TextBlock Text="Every screen, in balance." FontSize="11" Foreground="{DynamicResource MutedTextBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Button>

                <ItemsControl Grid.Row="1" Margin="0,28,0,0" ItemsSource="{Binding NavigationItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Label}" Command="{Binding DataContext.SelectSurfaceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding Surface}" Style="{StaticResource NavigationButton}"
                                    AutomationProperties.Name="{Binding AccessibleName}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="Private by design." FontWeight="SemiBold" />
                    <TextBlock Text="Local by default." Foreground="{DynamicResource MutedTextBrush}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="44,30,44,34">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="{Binding CurrentSurface.Title}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" />
                    <TextBlock Text="Adaptive screen comfort for Windows" FontSize="12" Foreground="{DynamicResource MutedTextBrush}" />
                </StackPanel>
                <Border DockPanel.Dock="Right" Padding="12,7" CornerRadius="6" Background="{DynamicResource SurfaceSubtleBrush}">
                    <TextBlock Text="{Binding AutoStatus}" FontWeight="SemiBold" />
                </Border>
            </DockPanel>

            <Grid x:Name="ContentHost" Grid.Row="1" RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform><TranslateTransform /></Grid.RenderTransform>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers><DataTrigger Binding="{Binding SelectedSurface}" Value="{x:Static presentation:ShellSurface.Home}"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <StackPanel VerticalAlignment="Center" MaxWidth="650" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding ComfortStateText}" FontSize="48" FontWeight="SemiBold" TextWrapping="Wrap" AutomationProperties.LiveSetting="Polite" />
                        <TextBlock Margin="0,14,0,0" Text="{Binding CurrentModeText}" FontSize="23" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock Margin="0,10,0,0" Text="{Binding Reason}" FontSize="17" TextWrapping="Wrap" Foreground="{DynamicResource MutedTextBrush}" />
                        <TextBlock Margin="0,34,0,0" Text="{Binding DisplaySummary}" FontSize="15" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                        <Button MinWidth="180" MinHeight="48" Content="{Binding PrimaryPauseText}" Command="{Binding PauseResumeCommand}" AutomationProperties.Name="Pause or resume Aptema" />
                        <Button Margin="12,0,0,0" MinWidth="130" Content="Adjust" Command="{Binding ShowQuickAdjustCommand}" Style="{StaticResource QuietButton}" AutomationProperties.Name="Adjust comfort" />
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.Style><Style TargetType="Grid"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding SelectedSurface}" Value="{x:Static presentation:ShellSurface.Displays}"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Grid.Style>
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <StackPanel><TextBlock Text="Your protected screens" FontSize="32" FontWeight="SemiBold" /><TextBlock Margin="0,8,0,0" Text="{Binding DisplaySummary}" Foreground="{DynamicResource MutedTextBrush}" /></StackPanel>
                    <ScrollViewer Grid.Row="1" Margin="0,24,0,12" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding DisplaySettingsDraft.Displays}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource SurfaceCard}" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="220" /></Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding NumberLabel}" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" />
                                                <TextBlock Margin="0,4,0,0" Text="{Binding Name}" FontSize="18" FontWeight="SemiBold" />
                                                <TextBlock Margin="0,5,0,0" Text="{Binding ControlMethod}" Foreground="{DynamicResource MutedTextBrush}" />
                                                <TextBlock Margin="0,4,0,0" Text="{Binding Guidance}" TextWrapping="Wrap" MaxWidth="430" Foreground="{DynamicResource MutedTextBrush}" />
                                                <StackPanel Margin="0,14,0,0" Orientation="Horizontal">
                                                    <Button Content="Identify" Command="{Binding DataContext.IdentifyDisplayCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" Style="{StaticResource QuietButton}" />
                                                    <Button Margin="8,0,0,0" Content="Test" Command="{Binding DataContext.TestDisplayCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" Style="{StaticResource QuietButton}" />
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <CheckBox Content="Protect this display" IsChecked="{Binding IsEnabled, Mode=TwoWay}" />
                                                <TextBlock Margin="0,10,0,4" Text="Comfort offset" FontWeight="SemiBold" />
                                                <Slider Minimum="-20" Maximum="20" TickFrequency="1" Value="{Binding BrightnessOffsetPercent, Mode=TwoWay}" />
                                                <TextBlock Margin="0,10,0,4" Text="Safe light range" FontWeight="SemiBold" />
                                                <StackPanel Orientation="Horizontal"><TextBox Width="64" Text="{Binding MinimumBrightnessPercent, Mode=TwoWay}" /><TextBlock Margin="8,4" Text="to" /><TextBox Width="64" Text="{Binding MaximumBrightnessPercent, Mode=TwoWay}" /></StackPanel>
                                                <TextBlock Margin="0,10,0,0" Text="{Binding Status}" FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <StackPanel Grid.Row="2" Orientation="Horizontal"><Button Content="Save displays" Command="{Binding SaveDisplaySettingsCommand}" /><Button Margin="10,0,0,0" Content="Cancel" Command="{Binding CancelDisplaySettingsCommand}" Style="{StaticResource QuietButton}" /></StackPanel>
                </Grid>

                <Grid>
                    <Grid.Style><Style TargetType="Grid"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding SelectedSurface}" Value="{x:Static presentation:ShellSurface.Applications}"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Grid.Style>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <StackPanel><TextBlock Text="Comfort that follows your work" FontSize="32" FontWeight="SemiBold"/><TextBlock Margin="0,8,0,0" Text="Only the app name and your chosen type are kept. Window titles are never saved." Foreground="{DynamicResource MutedTextBrush}"/></StackPanel>
                    <ScrollViewer Grid.Row="1" Margin="0,22,0,14" VerticalScrollBarVisibility="Auto"><StackPanel MaxWidth="700" HorizontalAlignment="Left">
                        <Border Style="{StaticResource SurfaceCard}"><StackPanel><TextBlock Text="Active now" Foreground="{DynamicResource MutedTextBrush}"/><TextBlock Margin="0,5,0,12" Text="{Binding PersonalizationDraft.CurrentApplicationName}" FontSize="20" FontWeight="SemiBold"/><ComboBox Width="260" HorizontalAlignment="Left" ItemsSource="{Binding PersonalizationDraft.AppCategories}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding PersonalizationDraft.SelectedApplicationCategory}" AutomationProperties.Name="Application type"/><Button Margin="0,12,0,0" HorizontalAlignment="Left" Content="Remember this app type" Command="{Binding PersonalizationDraft.SaveCurrentApplicationRuleCommand}"/></StackPanel></Border>
                        <TextBlock Margin="0,22,0,10" Text="Remembered apps" FontSize="18" FontWeight="SemiBold"/>
                        <ItemsControl ItemsSource="{Binding PersonalizationDraft.ApplicationRules}"><ItemsControl.ItemTemplate><DataTemplate><Border Style="{StaticResource SurfaceCard}" Margin="0,0,0,8"><DockPanel><TextBlock DockPanel.Dock="Right" Text="{Binding Category}" Foreground="{DynamicResource AccentBrush}"/><StackPanel><TextBlock Text="{Binding Name}" FontWeight="SemiBold"/><TextBlock Text="{Binding ProcessName}" Foreground="{DynamicResource MutedTextBrush}"/></StackPanel></DockPanel></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                    </StackPanel></ScrollViewer>
                    <StackPanel Grid.Row="2" Orientation="Horizontal"><Button Content="Save" Command="{Binding SavePersonalizationCommand}"/><Button Margin="10,0,0,0" Content="Cancel" Command="{Binding CancelPersonalizationCommand}" Style="{StaticResource QuietButton}"/></StackPanel>
                </Grid>

                <Grid>
                    <Grid.Style><Style TargetType="Grid"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding SelectedSurface}" Value="{x:Static presentation:ShellSurface.Profiles}"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Grid.Style>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <StackPanel><TextBlock Text="Choose how comfort feels" FontSize="32" FontWeight="SemiBold"/><TextBlock Margin="0,8,0,0" Text="Built-in modes stay protected. Create a personal variation when you need one." Foreground="{DynamicResource MutedTextBrush}"/></StackPanel>
                    <ScrollViewer Grid.Row="1" Margin="0,22,0,14"><StackPanel MaxWidth="700" HorizontalAlignment="Left">
                        <UniformGrid Columns="3"><Button Margin="0,0,8,0" Content="Light" Command="{Binding SetCalmCommand}" Style="{StaticResource QuietButton}"/><Button Margin="4,0" Content="Balanced" Command="{Binding SetBalancedCommand}"/><Button Margin="8,0,0,0" Content="Deep" Command="{Binding SetDeepComfortCommand}" Style="{StaticResource QuietButton}"/></UniformGrid>
                        <StackPanel Margin="0,24,0,14" Orientation="Horizontal"><TextBox Width="280" Text="{Binding PersonalizationDraft.NewProfileName, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="New profile name"/><Button Margin="10,0,0,0" Content="Create personal profile" Command="{Binding PersonalizationDraft.CreateProfileCommand}"/></StackPanel>
                        <ItemsControl ItemsSource="{Binding PersonalizationDraft.CustomProfiles}"><ItemsControl.ItemTemplate><DataTemplate><Border Style="{StaticResource SurfaceCard}" Margin="0,0,0,8"><DockPanel><Button DockPanel.Dock="Right" Content="Remove" Command="{Binding DataContext.PersonalizationDraft.RemoveProfileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding Id}" Style="{StaticResource QuietButton}"/><StackPanel><TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold"/><TextBlock Text="Personal profile" Foreground="{DynamicResource MutedTextBrush}"/></StackPanel></DockPanel></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                    </StackPanel></ScrollViewer>
                    <StackPanel Grid.Row="2" Orientation="Horizontal"><Button Content="Save" Command="{Binding SavePersonalizationCommand}"/><Button Margin="10,0,0,0" Content="Cancel" Command="{Binding CancelPersonalizationCommand}" Style="{StaticResource QuietButton}"/></StackPanel>
                </Grid>

                <Grid>
                    <Grid.Style><Style TargetType="Grid"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding SelectedSurface}" Value="{x:Static presentation:ShellSurface.Automation}"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Grid.Style>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <StackPanel><TextBlock Text="Quietly automatic" FontSize="32" FontWeight="SemiBold"/><TextBlock Margin="0,8,0,0" Text="Rules add small, gradual corrections and never bypass safety limits." Foreground="{DynamicResource MutedTextBrush}"/></StackPanel>
                    <ScrollViewer Grid.Row="1" Margin="0,22,0,14"><StackPanel MaxWidth="700" HorizontalAlignment="Left">
                        <Border Style="{StaticResource SurfaceCard}"><StackPanel><TextBlock Text="New comfort rule" FontSize="18" FontWeight="SemiBold"/><TextBox Margin="0,12,0,0" Width="300" HorizontalAlignment="Left" Text="{Binding PersonalizationDraft.NewAutomationName, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Rule name"/><ComboBox Margin="0,10,0,0" Width="180" HorizontalAlignment="Left" ItemsSource="{Binding PersonalizationDraft.DayPhases}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding PersonalizationDraft.NewAutomationPhase}"/><TextBlock Margin="0,14,0,4" Text="Make light softer"/><Slider Minimum="-12" Maximum="0" Value="{Binding PersonalizationDraft.NewAutomationBrightnessOffset}"/><TextBlock Margin="0,12,0,4" Text="Add warmth"/><Slider Minimum="-480" Maximum="0" TickFrequency="20" Value="{Binding PersonalizationDraft.NewAutomationWarmthOffset}"/><Button Margin="0,14,0,0" HorizontalAlignment="Left" Content="Add rule" Command="{Binding PersonalizationDraft.CreateAutomationRuleCommand}"/></StackPanel></Border>
                        <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding PersonalizationDraft.AutomationRules}"><ItemsControl.ItemTemplate><DataTemplate><Border Style="{StaticResource SurfaceCard}" Margin="0,0,0,8"><DockPanel><Button DockPanel.Dock="Right" Content="Remove" Command="{Binding DataContext.PersonalizationDraft.RemoveAutomationRuleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding Id}" Style="{StaticResource QuietButton}"/><StackPanel><TextBlock Text="{Binding Name}" FontWeight="SemiBold"/><TextBlock Text="{Binding DayPhase}" Foreground="{DynamicResource MutedTextBrush}"/></StackPanel></DockPanel></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                    </StackPanel></ScrollViewer>
                    <StackPanel Grid.Row="2" Orientation="Horizontal"><Button Content="Save" Command="{Binding SavePersonalizationCommand}"/><Button Margin="10,0,0,0" Content="Cancel" Command="{Binding CancelPersonalizationCommand}" Style="{StaticResource QuietButton}"/></StackPanel>
                </Grid>

                <Grid>
                    <Grid.Style><Style TargetType="Grid"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding SelectedSurface}" Value="{x:Static presentation:ShellSurface.Learning}"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Grid.Style>
                    <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <StackPanel VerticalAlignment="Center" MaxWidth="620" HorizontalAlignment="Left"><TextBlock Text="Your comfort, remembered" FontSize="32" FontWeight="SemiBold"/><TextBlock Margin="0,9,0,24" Text="Aptema combines corrections into small local signals. It never keeps screenshots, pixels or window titles." TextWrapping="Wrap" Foreground="{DynamicResource MutedTextBrush}"/><Border Style="{StaticResource SurfaceCard}"><StackPanel><TextBlock Text="Current decision" Foreground="{DynamicResource MutedTextBrush}"/><TextBlock Margin="0,5,0,0" Text="{Binding DecisionSourceText}" FontSize="18" FontWeight="SemiBold"/><TextBlock Margin="0,3,0,0" Text="{Binding DecisionConfidenceText}" Foreground="{DynamicResource AccentBrush}"/><TextBlock Margin="0,3,0,18" Text="{Binding DecisionRuleText}" Foreground="{DynamicResource MutedTextBrush}"/><TextBlock Text="Local feedback samples" Foreground="{DynamicResource MutedTextBrush}"/><TextBlock Margin="0,4,0,12" Text="{Binding PersonalizationDraft.LearningSignalCount}" FontSize="34" FontWeight="SemiBold"/><Button HorizontalAlignment="Left" Content="Forget learned comfort" Command="{Binding PersonalizationDraft.ResetLearningCommand}" Style="{StaticResource QuietButton}"/></StackPanel></Border></StackPanel>
                    <StackPanel Grid.Row="1" Orientation="Horizontal"><Button Content="Save" Command="{Binding SavePersonalizationCommand}"/><Button Margin="10,0,0,0" Content="Cancel" Command="{Binding CancelPersonalizationCommand}" Style="{StaticResource QuietButton}"/></StackPanel>
                </Grid>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Style><Style TargetType="ScrollViewer"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding SelectedSurface}" Value="{x:Static presentation:ShellSurface.System}"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></ScrollViewer.Style>
                    <StackPanel MaxWidth="680" HorizontalAlignment="Left">
                        <TextBlock Text="Simple defaults, clear control" FontSize="32" FontWeight="SemiBold" />
                        <TextBlock Margin="0,8,0,24" Text="Everything stays on this PC." Foreground="{DynamicResource MutedTextBrush}" />
                        <CheckBox Content="Start Aptema with Windows" IsChecked="{Binding SettingsDraft.StartWithWindows, Mode=TwoWay}" AutomationProperties.Name="Start Aptema with Windows" />
                        <CheckBox Content="Adapt bright pages locally" IsChecked="{Binding SettingsDraft.EnableContentBrightnessAnalysis, Mode=TwoWay}" AutomationProperties.Name="Adapt bright pages locally" />
                        <CheckBox Content="Protect fullscreen games and video" IsChecked="{Binding SettingsDraft.GamingVideoProtection, Mode=TwoWay}" AutomationProperties.Name="Protect fullscreen games and video" />
                        <CheckBox Content="Use less power on battery" IsChecked="{Binding SettingsDraft.ReduceWorkOnBattery, Mode=TwoWay}" AutomationProperties.Name="Use less power on battery" />
                        <CheckBox Content="Start in recovery mode" IsChecked="{Binding SettingsDraft.SafeModeEnabled, Mode=TwoWay}" AutomationProperties.Name="Start Aptema in recovery mode" />
                        <Border Margin="0,18,0,0" Padding="14" Background="{DynamicResource SurfaceSubtleBrush}" CornerRadius="6">
                            <StackPanel><TextBlock Text="System health" FontWeight="SemiBold" /><TextBlock Margin="0,4,0,0" Text="{Binding SystemHealthText}" TextWrapping="Wrap" Foreground="{DynamicResource MutedTextBrush}" /><TextBlock Margin="0,4,0,0" Text="{Binding SafeModeStatusText}" TextWrapping="Wrap" Foreground="{DynamicResource MutedTextBrush}" /><Button Margin="0,12,0,0" HorizontalAlignment="Left" Content="Create support package" Command="{Binding CreateSupportBundleCommand}" Style="{StaticResource QuietButton}" /></StackPanel>
                        </Border>
                        <TextBlock Margin="0,22,0,6" Text="Comfort intensity" FontWeight="SemiBold" />
                        <Slider Minimum="0" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="True" Value="{Binding SettingsDraft.ComfortIntensity, Mode=TwoWay}" AutomationProperties.Name="Comfort intensity" />
                        <StackPanel Margin="0,26,0,0" Orientation="Horizontal"><Button Content="Save" Command="{Binding SaveSettingsCommand}" /><Button Margin="10,0,0,0" Content="Cancel" Command="{Binding CancelSettingsCommand}" Style="{StaticResource QuietButton}" /></StackPanel>
                        <TextBlock Margin="0,28,0,0" Text="Private by design. Local by default." FontWeight="SemiBold" /><TextBlock Margin="0,5,0,0" Text="No account, cloud sync or telemetry. Screen samples are processed in memory only when you enable them." TextWrapping="Wrap" Foreground="{DynamicResource MutedTextBrush}" />
                        <Border Margin="0,20,0,0" Padding="14" Background="{DynamicResource SurfaceSubtleBrush}" CornerRadius="6">
                            <StackPanel><TextBlock Text="Quick Adjust shortcut" FontWeight="SemiBold" /><TextBlock Margin="0,4,0,0" Text="{Binding ShortcutStatusText}" TextWrapping="Wrap" Foreground="{DynamicResource MutedTextBrush}" /><Button Margin="0,10,0,0" HorizontalAlignment="Left" Content="Open Adjust" Command="{Binding ShowQuickAdjustCommand}" Style="{StaticResource QuietButton}" /></StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
