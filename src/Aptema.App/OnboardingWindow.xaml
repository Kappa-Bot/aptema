<Window x:Class="Aptema.App.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Aptema.App.ViewModels"
        Title="Set up Aptema" Icon="Assets/Aptema.ico" Width="720" Height="560"
        MinWidth="640" MinHeight="500" WindowStartupLocation="CenterScreen">
    <Grid Margin="32">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <DockPanel>
            <Image Width="38" Height="38" Source="Assets/Aptema-48.png" />
            <StackPanel Margin="12,0,0,0"><TextBlock Text="Aptema" FontSize="22" FontWeight="SemiBold" /><TextBlock Text="Every screen, in balance." Foreground="{DynamicResource MutedTextBrush}" /></StackPanel>
            <TextBlock DockPanel.Dock="Right" Text="{Binding StepNumber, StringFormat=Step {0} of 6}" VerticalAlignment="Center" Foreground="{DynamicResource MutedTextBrush}" />
        </DockPanel>

        <Grid Grid.Row="1" Margin="0,30,0,20">
            <StackPanel><StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:OnboardingStep.Welcome}"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                <TextBlock Text="Comfort that stays private" FontSize="34" FontWeight="SemiBold"/><TextBlock Margin="0,12,0,0" MaxWidth="560" TextWrapping="Wrap" Text="Aptema adapts your displays locally. It never sends screen content, stores screenshots or requires an account." Foreground="{DynamicResource MutedTextBrush}"/>
                <CheckBox Margin="0,28,0,0" Content="I understand that Aptema works locally on this PC" IsChecked="{Binding PrivacyAccepted, Mode=TwoWay}"/>
            </StackPanel>
            <StackPanel><StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:OnboardingStep.Displays}"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                <TextBlock Text="Your displays" FontSize="34" FontWeight="SemiBold"/><TextBlock Margin="0,8,0,18" Text="Choose a display and identify it without changing brightness." Foreground="{DynamicResource MutedTextBrush}"/>
                <ListBox Height="220" ItemsSource="{Binding Displays}" SelectedItem="{Binding SelectedDisplay}" DisplayMemberPath="Label"/>
                <Button Margin="0,14,0,0" HorizontalAlignment="Left" Content="Identify selected display" Command="{Binding IdentifySelectedDisplayCommand}" Style="{StaticResource QuietButton}"/>
            </StackPanel>
            <StackPanel><StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:OnboardingStep.MethodCheck}"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                <TextBlock Text="Check comfort control" FontSize="34" FontWeight="SemiBold"/><TextBlock Margin="0,10,0,0" MaxWidth="560" TextWrapping="Wrap" Text="Optional. Test makes one mild, reversible adjustment on the selected display, then restores it after two seconds." Foreground="{DynamicResource MutedTextBrush}"/>
                <Button Margin="0,24,0,0" HorizontalAlignment="Left" Content="Run reversible test" Command="{Binding TestSelectedDisplayCommand}"/>
            </StackPanel>
            <StackPanel><StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:OnboardingStep.Calibration}"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                <TextBlock Text="Choose your starting comfort" FontSize="34" FontWeight="SemiBold"/><TextBlock Margin="0,10,0,24" Text="Balanced works well for most rooms. Aptema learns from later corrections." Foreground="{DynamicResource MutedTextBrush}"/>
                <Slider Width="500" HorizontalAlignment="Left" Minimum="0" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="True" Value="{Binding ComfortIntensity}" AutomationProperties.Name="Starting comfort intensity"/>
            </StackPanel>
            <StackPanel><StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:OnboardingStep.Schedule}"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                <TextBlock Text="Fit your day" FontSize="34" FontWeight="SemiBold"/><TextBlock Margin="0,10,0,22" Text="These times guide warmer evening light. They do not create alarms." Foreground="{DynamicResource MutedTextBrush}"/>
                <StackPanel Orientation="Horizontal"><StackPanel><TextBlock Text="Wake time"/><TextBox Width="110" Text="{Binding WakeTime}"/></StackPanel><StackPanel Margin="20,0,0,0"><TextBlock Text="Sleep time"/><TextBox Width="110" Text="{Binding SleepTime}"/></StackPanel></StackPanel>
                <CheckBox Margin="0,24,0,0" Content="Keep games, videos and presentations stable" IsChecked="{Binding FullscreenProtection}"/>
            </StackPanel>
            <StackPanel><StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:OnboardingStep.Finish}"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                <TextBlock Text="Ready to stay comfortable" FontSize="34" FontWeight="SemiBold"/><TextBlock Margin="0,10,0,0" MaxWidth="550" TextWrapping="Wrap" Text="Aptema will run quietly in the taskbar icons area. Use Adjust whenever the screen feels wrong." Foreground="{DynamicResource MutedTextBrush}"/>
                <CheckBox Margin="0,26,0,0" Content="Start Aptema with Windows" IsChecked="{Binding StartWithWindows}"/>
            </StackPanel>
        </Grid>

        <DockPanel Grid.Row="2">
            <Button DockPanel.Dock="Left" Content="Back" Command="{Binding BackCommand}" Style="{StaticResource QuietButton}" IsEnabled="{Binding CanMoveBack}"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Margin="0,0,10,0" Content="Skip" Command="{Binding SkipCommand}" Style="{StaticResource QuietButton}"/>
                <Button MinWidth="110" Content="Next" IsEnabled="{Binding CanMoveNext}" IsDefault="True" Click="Next_Click"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
