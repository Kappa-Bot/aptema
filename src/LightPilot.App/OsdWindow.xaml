<Window x:Class="LightPilot.App.OsdWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="300"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        AutomationProperties.Name="Aptema adjustment">
    <Border Margin="8" Padding="16" CornerRadius="8" Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrushMuted}" BorderThickness="1">
        <Border.Effect><DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.2" /></Border.Effect>
        <DockPanel>
            <Image DockPanel.Dock="Left" Source="Assets/Aptema-32.png" Width="28" Height="28" Margin="0,0,12,0" />
            <Button x:Name="UndoButton" DockPanel.Dock="Right" Content="Undo" Style="{StaticResource QuietButton}" Click="Undo_Click" Margin="12,0,0,0" />
            <TextBlock x:Name="MessageText" VerticalAlignment="Center" FontWeight="SemiBold" TextWrapping="Wrap" AutomationProperties.LiveSetting="Polite" />
        </DockPanel>
    </Border>
</Window>
