<Window x:Class="LightPilot.App.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to Aptema"
        Icon="Assets/Aptema.ico"
        Width="430"
        Height="430"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
            <Border Width="74"
                    Height="74"
                    CornerRadius="22"
                    Background="{DynamicResource SurfaceSubtleBrush}"
                    HorizontalAlignment="Center">
                <Image Source="Assets/Aptema-64.png"
                       Width="56"
                       Height="56"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center" />
            </Border>
            <TextBlock Margin="0,16,0,0"
                       Text="Aptema"
                       FontSize="28"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Every screen, in balance."
                       Foreground="{StaticResource MutedTextBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,28,0,0">
            <TextBlock Text="Start with Balanced."
                       FontSize="18"
                       FontWeight="SemiBold" />
            <TextBlock Margin="0,5,0,0"
                       Text="Use Too bright or Too dim whenever it feels off. Aptema adapts gently from there."
                       TextWrapping="Wrap"
                       Foreground="{StaticResource MutedTextBrush}" />

            <TextBlock Margin="0,18,0,0"
                       Text="Tray first."
                       FontSize="18"
                       FontWeight="SemiBold" />
            <TextBlock Margin="0,5,0,0"
                       Text="Close the window any time. It keeps running quietly in the taskbar icons area."
                       TextWrapping="Wrap"
                       Foreground="{StaticResource MutedTextBrush}" />
        </StackPanel>

        <Button Grid.Row="2"
                Content="Start"
                Width="110"
                HorizontalAlignment="Right"
                IsDefault="True"
                Click="Start_Click" />
    </Grid>
</Window>
