<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{x:Static SystemColors.WindowColor}" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{x:Static SystemColors.ControlColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{x:Static SystemColors.WindowColor}" />
    <SolidColorBrush x:Key="SurfaceSubtleBrush" Color="{x:Static SystemColors.ControlColor}" />
    <SolidColorBrush x:Key="BorderBrushMuted" Color="{x:Static SystemColors.WindowTextColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{x:Static SystemColors.WindowTextColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{x:Static SystemColors.GrayTextColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{x:Static SystemColors.HighlightColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{x:Static SystemColors.HotTrackColor}" />
    <SolidColorBrush x:Key="AccentTextBrush" Color="{x:Static SystemColors.HighlightTextColor}" />
    <SolidColorBrush x:Key="WarmAccentBrush" Color="{x:Static SystemColors.HighlightColor}" />
    <SolidColorBrush x:Key="FocusBrush" Color="{x:Static SystemColors.HighlightColor}" />
    <SolidColorBrush x:Key="SelectionBrush" Color="{x:Static SystemColors.ControlColor}" />
</ResourceDictionary>
